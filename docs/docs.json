{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Bossa",
  "description": "Your AI agent's long-term memory. Remember everything. As simple as files, as powerful as Postgres.",
  "colors": {
    "primary": "#16A34A",
    "light": "#FACC15",
    "dark": "#15803D"
  },
  "fonts": {
    "heading": { "family": "Inter" },
    "body": { "family": "Inter" }
  },
  "background": {
    "color": {
      "light": "#F7FDF7",
      "dark": "#0A0F0A"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Get Started",
        "href": "/GETTING_STARTED"
      },
      {
        "label": "API",
        "href": "/REST_API"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Try Bossa",
      "href": "https://github.com/vinny380/bossa"
    }
  },
  "footer": {
    "links": [
      {
        "header": "Documentation",
        "items": [
          { "label": "Getting Started", "href": "/GETTING_STARTED" },
          { "label": "CLI Reference", "href": "/CLI" },
          { "label": "REST API", "href": "/REST_API" }
        ]
      },
      {
        "header": "Integration",
        "items": [
          { "label": "MCP", "href": "/MCP" },
          { "label": "Agent Integration", "href": "/AGENT_INTEGRATION" }
        ]
      }
    ]
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "icon": "rocket",
        "pages": ["index", "GETTING_STARTED", "WHY_FILESYSTEM", "DYNAMIC_CONTEXT_DISCOVERY", "ADD_DOCS_AS_MCP"]
      },
      {
        "group": "Reference",
        "icon": "book-open",
        "pages": ["CLI", "REST_API", "MCP"]
      },
      {
        "group": "Integration",
        "icon": "puzzle",
        "pages": ["AGENT_INTEGRATION", "USE_CASES"]
      },
      {
        "group": "Deployment",
        "icon": "server",
        "pages": ["SELF_HOSTING"]
      }
    ]
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": {
      "theme": {
        "light": "min-light",
        "dark": "min-dark"
      }
    }
  },
  "appearance": {
    "default": "system"
  },
  "metadata": {
    "timestamp": true
  },
  "contextual": {
    "options": [
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
