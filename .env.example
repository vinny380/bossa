# ==============================================================================
# Environment (development | production)
# ==============================================================================
# Switch with one variable. Development: relaxed auth, localhost defaults.
# Production: API key required, sk-default blocked.
ENV=development

# ==============================================================================
# Database
# ==============================================================================
# Supabase (production):
# DATABASE_URL=postgres://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres
#
# Local Docker (development):
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bossa

# Workspace fallback when no API key is provided
DEFAULT_WORKSPACE_ID=00000000-0000-0000-0000-000000000001

# Dev key seeded in migration 002; blocked when ENV=production
DEFAULT_API_KEY=sk-default

# Local Docker (optional; used by docker compose for the Postgres container)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bossa

# ==============================================================================
# Control plane / Supabase Auth (backend + CLI for self-hosted)
# ==============================================================================
# Backend needs these for GET /auth/config and JWT verification.
# Self-hosted CLI users need them; managed service users get them from the API.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard

# For JWT validation (backend only; required when using control plane in production)
# SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard

# Owner role: comma-separated Supabase Auth user IDs that bypass usage limits (core devs)
# OWNER_USER_IDS=uuid1,uuid2

# Bossa API base URL. CLI defaults to managed service. For local dev: http://localhost:8000
BOSSA_API_URL=https://filesystem-fawn.vercel.app

# HTTP timeout in seconds for CLI requests (default 30; helps with serverless cold starts)
BOSSA_TIMEOUT=30

# Stripe (optional; omit to disable billing)
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_MONTHLY=price_...
# STRIPE_PRICE_ID_YEARLY=price_...
# BOSSA_BILLING_SUCCESS_URL=https://bossa.mintlify.app/GETTING_STARTED
# BOSSA_BILLING_CANCEL_URL=https://bossa.mintlify.app/PRICING

# ==============================================================================
# Examples / Agents
# ==============================================================================
OPENAI_API_KEY=sk-...

# Bossa workspace API key (required for examples and CLI file ops)
BOSSA_API_KEY=sk-default