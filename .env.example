# ==============================================================================
# Database
# ==============================================================================
# Supabase (production):
# DATABASE_URL=postgres://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres
#
# Local Docker (development):
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bossa

# Workspace fallback when no API key is provided
DEFAULT_WORKSPACE_ID=00000000-0000-0000-0000-000000000001

# Local Docker (optional; used by docker compose for the Postgres container)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bossa

# ==============================================================================
# Control plane / CLI (Supabase Auth)
# ==============================================================================
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard

# For JWT validation (only needed when using the control plane in production)
# SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard

# Optional: where the CLI points (defaults to hosted Bossa)
# BOSSA_API_URL=https://your-deployment.vercel.app

# ==============================================================================
# Examples / Agents
# ==============================================================================
OPENAI_API_KEY=sk-...

# Optional: Bossa workspace API key (default: sk-default for dev)
BOSSA_API_KEY=sk-default

# Optional: Bossa server URL (default: http://localhost:8000/mcp)
BOSSA_URL=http://localhost:8000/mcp